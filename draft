<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>El Sabor Oaxaqueño</title>

<style>
/* =========================
   VARIABLES DE DISEÑO
========================= */
:root{
  --terracota:#C96A3D;
  --naranja:#D97706;
  --beige:#F5E6D3;
  --cafe:#4A2C1A;
  --agave:#4F6F52;
  --blanco:#ffffff;
}

/* =========================
   RESET BÁSICO
========================= */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  background:var(--beige);
  color:var(--cafe);
  overflow-x:hidden;
}

/* =========================
   UTILIDADES
========================= */
.container{
  width:90%;
  max-width:1200px;
  margin:auto;
}

img{
  max-width:100%;
  display:block;
  border-radius:18px;
  transition:transform .3s ease, box-shadow .3s ease;
}

/* Hover premium para imágenes */
img:hover{
  transform:scale(1.03);
}

/* =========================
   BOTONES PREMIUM
========================= */
.btn{
  display:inline-block;
  padding:14px 22px;
  border-radius:999px;
  text-decoration:none;
  font-weight:600;
  transition:all .3s ease;
  cursor:pointer;
}

.btn-primary{
  background:var(--naranja);
  color:white;
  box-shadow:0 10px 25px rgba(217,119,6,.25);
}

.btn-primary:hover{
  transform:translateY(-3px) scale(1.05);
  box-shadow:0 15px 30px rgba(217,119,6,.35);
}

.btn-outline{
  border:2px solid var(--cafe);
  color:var(--cafe);
  background:transparent;
}

.btn-outline:hover{
  background:var(--cafe);
  color:white;
  transform:translateY(-3px) scale(1.05);
}

/* =========================
   EFECTO DE APARICIÓN (SCROLL)
========================= */
.reveal{
  opacity:0;
  transform:translateY(40px);
  transition:all .8s ease;
}

.reveal.active{
  opacity:1;
  transform:translateY(0);
}

/* =========================
   NAVBAR BASE
========================= */
.navbar{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  padding:18px 5%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  z-index:1000;
  transition:.4s ease;
  background:rgba(245,230,211,.6);
  backdrop-filter: blur(10px);
}

.navbar.scrolled{
  background:rgba(74,44,26,.95);
}

/* LOGO */
.logo{
  display:flex;
  align-items:center;
  gap:10px;
  font-weight:800;
  color:var(--cafe);
}

.navbar.scrolled .logo{
  color:white;
}

/* MENU */
.nav-links{
  display:flex;
  gap:20px;
}

.nav-links a{
  text-decoration:none;
  color:var(--cafe);
  font-weight:500;
  transition:.3s;
}

.navbar.scrolled .nav-links a{
  color:white;
}

.nav-links a:hover{
  color:var(--naranja);
}

/* HAMBURGUESA */
.menu-toggle{
  display:none;
  font-size:26px;
  cursor:pointer;
}

/* =========================
   RESPONSIVE NAVBAR
========================= */
@media(max-width:768px){
  .menu-toggle{
    display:block;
  }

  .nav-links{
    position:absolute;
    top:70px;
    left:0;
    width:100%;
    background:var(--cafe);
    flex-direction:column;
    padding:20px;
    display:none;
  }

  .nav-links.active{
    display:flex;
  }

  .nav-links a{
    color:white;
    padding:10px 0;
  }
}
</style>

<!-- =================================================================
     style 1.a3
==================================================================== -->

<style>

/* GRID */
.menu-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(240px, 1fr));
  gap:25px;
}

/* CARD */
.menu-card{
  background:white;
  border-radius:22px;
  overflow:hidden;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  transition:all .3s ease;
  cursor:pointer;
}

.menu-card:hover{
  transform:translateY(-8px) scale(1.02);
  box-shadow:0 20px 40px rgba(0,0,0,0.15);
}

/* IMAGE WRAPPER */
.img-wrapper{
  position:relative;
  overflow:hidden;
  border-radius:22px 22px 0 0;
}

.img-wrapper img{
  width:100%;
  height:200px;
  object-fit:cover;
  transition:transform .4s ease;
}

.menu-card:hover img{
  transform:scale(1.08);
}

/* OVERLAY DESCRIPCIÓN */
.overlay{
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  background:rgba(0,0,0,0.65);
  color:white;
  padding:12px;
  font-size:0.9rem;
  transform:translateY(100%);
  transition:all .3s ease;
}

.menu-card:hover .overlay{
  transform:translateY(0);
}

/* TEXTOS */
.menu-card h3{
  padding:15px 15px 5px 15px;
}

.menu-card p{
  padding:0 15px 15px 15px;
  color:var(--naranja);
  font-weight:600;
}

</style>

<!-- =================================================================
     style 1a.4
==================================================================== -->

<style>


/* =========================
   GALERÍA
========================= */


.gallery-section{

padding:100px 0;

background:var(--beige);

}



.gallery-header{

text-align:center;

margin-bottom:45px;

}



.gallery-header h2{

font-size:2.5rem;

color:var(--cafe);

}



.gallery-header p{

margin-top:10px;

opacity:.75;

}



/* =========================
   CARRUSEL
========================= */


.carousel-wrapper{

position:relative;

display:flex;

align-items:center;

}



.carousel-window{

overflow:hidden;

width:100%;

}



.carousel-track{

display:flex;

gap:25px;

transition:transform .7s ease;

}



/* =========================
   TARJETAS IMAGEN
========================= */


.gallery-card{

min-width:300px;

height:380px;

border-radius:25px;

overflow:hidden;

background:white;

padding:10px;

box-shadow:

0 15px 35px rgba(0,0,0,.12);

transition:

transform .35s ease,

box-shadow .35s ease;

}



.gallery-card:hover{

transform:

translateY(-10px)

scale(1.03);

box-shadow:

0 25px 45px rgba(0,0,0,.2);

}



.gallery-card img{

width:100%;

height:100%;

object-fit:cover;

border-radius:18px;

}





/* =========================
   BOTONES CARRUSEL
========================= */


.gallery-btn{

position:absolute;

z-index:5;

width:45px;

height:45px;

border:none;

border-radius:50%;

background:var(--cafe);

color:white;

font-size:28px;

cursor:pointer;

transition:.3s;

}



.gallery-btn:hover{

transform:

scale(1.15);

background:var(--naranja);

}



.prev{

left:-15px;

}



.next{

right:-15px;

}




/* =========================
   RESPONSIVE
========================= */


@media(max-width:768px){


.gallery-card{

min-width:260px;

height:330px;

}


.gallery-btn{

display:none;

}


}



</style>

<!-- =================================================================
     style 1a.5
==================================================================== -->

<style>

/* ======================================
   TESTIMONIOS
====================================== */


.testimonials-section{

padding:100px 0;

background:white;

}



.testimonial-header{

text-align:center;

margin-bottom:50px;

}



.testimonial-header h2{

font-size:2.5rem;

color:var(--cafe);

}




.testimonial-slider{

position:relative;

display:flex;

align-items:center;

}



.testimonial-window{

overflow:hidden;

width:100%;

}



.testimonial-track{

display:flex;

transition:.6s ease;

}



.testimonial-card{

min-width:100%;

padding:45px;

text-align:center;

background:var(--beige);

border-radius:25px;

box-shadow:

0 15px 35px rgba(0,0,0,.1);

}



.stars{

color:var(--naranja);

font-size:28px;

letter-spacing:5px;

margin-bottom:20px;

}



.testimonial-card p{

font-size:1.2rem;

font-style:italic;

line-height:1.7;

}



.testimonial-card h4{

margin-top:25px;

color:var(--cafe);

}



.testimonial-card span{

opacity:.7;

}




.testimonial-btn{

position:absolute;

z-index:2;

width:45px;

height:45px;

border-radius:50%;

border:none;

background:var(--cafe);

color:white;

font-size:28px;

cursor:pointer;

transition:.3s;

}



.testimonial-btn:hover{

transform:scale(1.15);

background:var(--naranja);

}



.prev-testimonial{

left:-15px;

}



.next-testimonial{

right:-15px;

}





/* ======================================
   CONTADORES
====================================== */


.stats-section{

padding:80px 0;

background:var(--cafe);

color:white;

}



.stats-grid{

display:grid;

grid-template-columns:repeat(3,1fr);

gap:30px;

}



.stat-card{

text-align:center;

}



.stat-card h3{

font-size:3rem;

color:var(--naranja);

}



.stat-card p{

font-size:1.1rem;

}

@media(max-width:768px){

.stats-grid{

grid-template-columns:1fr;
}

.testimonial-card{

padding:30px 20px;
}

}
</style>

<!-- =================================================================
     style 1a.6
==================================================================== -->

<style>
/* ======================================
   RESERVACIONES
====================================== */

.reservation-section{
padding:100px 0;
background:#fff;
}

.reservation-header{
text-align:center;
margin-bottom:45px;
}

.reservation-header h2{
font-size:2.5rem;
color:var(--cafe);
}

.reservation-header p{
margin-top:10px;
opacity:.75;
}

.reservation-box{
background:var(--beige);
padding:40px;
border-radius:30px;
box-shadow:0 20px 45px rgba(0,0,0,.12);
}

.form-grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:20px;
}

.form-group{
display:flex;
flex-direction:column;
gap:8px;
}

.form-group label{
font-weight:600;
color:var(--cafe);
}

.form-group input,
.form-group select,
.form-group textarea{
padding:14px;
border-radius:15px;
border:1px solid rgba(74,44,26,.2);
font-size:1rem;
background:white;
outline:none;
transition:.3s;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus{
border-color:var(--naranja);
transform:scale(1.02);
}

textarea{
min-height:120px;
resize:none;
}

.full{
margin-top:20px;
}

.submit-btn{
margin-top:25px;
border:none;
}


/* MODAL */

.modal{
position:fixed;
inset:0;
background:rgba(0,0,0,.55);
display:none;
align-items:center;
justify-content:center;
z-index:2000;
}

.modal.active{
display:flex;
}

.modal-content{
background:white;
padding:40px;
border-radius:25px;
text-align:center;
max-width:400px;
animation:modalIn .4s ease;
}

.modal-content h3{
color:var(--cafe);
font-size:1.8rem;
margin-bottom:15px;
}

@keyframes modalIn{
from{
opacity:0;
transform:translateY(30px) scale(.9);
}
to{
opacity:1;
transform:translateY(0) scale(1);
}
}


@media(max-width:768px){

.form-grid{
grid-template-columns:1fr;
}

.reservation-box{
padding:25px;
}

}
</style>

<!-- =================================================================
    style 1a.7
==================================================================== -->
<style>
/* ======================================
   UBICACIÓN
====================================== */

.location-section{
padding:100px 0;
background:var(--beige);
}

.location-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.location-info h2{
font-size:2.5rem;
color:var(--cafe);
margin-bottom:20px;
}

.location-info p{
line-height:1.7;
margin-bottom:25px;
}

.info-item{
display:flex;
flex-direction:column;
gap:5px;
margin-bottom:18px;
}

.info-item strong{
color:var(--naranja);
}


/* MAPA */

.map-card{
background:white;
padding:15px;
border-radius:30px;
box-shadow:0 20px 45px rgba(0,0,0,.15);
}


.fake-map{
height:420px;
border-radius:22px;
background:
linear-gradient(
135deg,
#d9c7ad,
#f5e6d3
);
display:flex;
align-items:center;
justify-content:center;
flex-direction:column;
position:relative;
overflow:hidden;
}


.fake-map:before{
content:"";
position:absolute;
width:500px;
height:500px;
border-radius:50%;
border:2px dashed rgba(74,44,26,.2);
}


.map-pin{
font-size:45px;
z-index:2;
animation:pulsePin 2s infinite;
}


.map-label{
margin-top:15px;
background:white;
padding:10px 20px;
border-radius:20px;
box-shadow:0 10px 20px rgba(0,0,0,.1);
z-index:2;
}


@keyframes pulsePin{

50%{
transform:scale(1.15);
}

}


/* ======================================
   FOOTER
====================================== */

.footer{
background:var(--cafe);
color:white;
padding:60px 0 20px;
}


.footer-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:40px;
}


.footer-logo{
display:flex;
align-items:center;
gap:15px;
}


.footer h4{
color:var(--naranja);
margin-bottom:15px;
}


.footer p{
opacity:.85;
line-height:1.6;
}


.social-links{
display:flex;
flex-direction:column;
gap:10px;
}


.social-links a{
color:white;
text-decoration:none;
transition:.3s;
}


.social-links a:hover{
color:var(--naranja);
transform:translateX(5px);
}


.footer-bottom{
text-align:center;
margin-top:40px;
padding-top:20px;
border-top:1px solid rgba(255,255,255,.15);
opacity:.7;
}


@media(max-width:768px){

.location-grid{
grid-template-columns:1fr;
}

.footer-grid{
grid-template-columns:1fr;
}

.fake-map{
height:300px;
}

}
</style>

</head>
